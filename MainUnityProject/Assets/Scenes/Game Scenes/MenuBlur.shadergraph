    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "SpiralBlurCustomFunction (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -516.9999389648438,
            "y": 93.0,
            "width": 300.99993896484377,
