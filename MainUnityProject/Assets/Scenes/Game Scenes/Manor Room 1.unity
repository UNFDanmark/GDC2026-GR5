  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Dear Diary\nEdward and I was wedded yesterday, my bellonging was moved
    to this office and the bedroom next door. \nThankfully we do not share a bed,
    unless he wishes to have a tiff with me. He is violent and ruthless, but finish
    quickly.\nWe do not share our meals either, and furthermore he has made me eat
    in my quarters.\nI hope our comming years will improve.\n\nYours truly\nElaine"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 3ffe376258b28aa48a8dd20f8808cde4, type: 2}
